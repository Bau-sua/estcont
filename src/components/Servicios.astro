---
const servicios = [
  {
    titulo: "Contabilidad",
    descripcion: "Registramos y ordenamos tus operaciones mes a mes. Balances, libros contables y reportes claros para que sepas dónde está parada tu empresa.",
    icono: "M9 7h6m-6 4h6m-6 4h6M5 7h.01M5 11h.01M5 15h.01M4 3h16a1 1 0 011 1v16a1 1 0 01-1 1H4a1 1 0 01-1-1V4a1 1 0 011-1z",
  },
  {
    titulo: "Impuestos",
    descripcion: "Liquidación de IVA, Ganancias, Bienes Personales e Ingresos Brutos. Planificamos tu carga fiscal para que pagues solo lo justo.",
    icono: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  },
  {
    titulo: "Sueldos",
    descripcion: "Liquidación de haberes, cargas sociales, recibos digitales y novedades ante AFIP. Todo listo para que tus empleados cobren en fecha.",
    icono: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z",
  },
];
---

<section id="servicios" class="px-6 max-w-5xl mx-auto py-24">
  <span class="text-brand font-medium text-sm tracking-widest uppercase">
    Servicios
  </span>
  <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900 mt-3 mb-16">
    Todo lo que necesitás,<br />en un solo lugar.
  </h2>
  <div class="grid sm:grid-cols-3 gap-8">
    {
      servicios.map((s) => (
        <div class="group">
          <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-cream text-brand mb-5 group-hover:bg-brand/10 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={s.icono} />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">{s.titulo}</h3>
          <p class="text-muted leading-relaxed">{s.descripcion}</p>
        </div>
      ))
    }
  </div>
</section>
