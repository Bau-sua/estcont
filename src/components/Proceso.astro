---
const pasos = [
  {
    numero: "01",
    titulo: "Analizamos",
    descripcion: "Revisamos tu situación fiscal y la realidad de tu negocio. Sin recetas genéricas, cada caso es único.",
  },
  {
    numero: "02",
    titulo: "Planificamos",
    descripcion: "Armamos una estrategia a medida: impositiva, contable y de negocio. Anticipamos escenarios para evitar sorpresas.",
  },
  {
    numero: "03",
    titulo: "Acompañamos",
    descripcion: "Seguimiento continuo, informes periódicos y asesoramiento permanente. No solo cumplimos, te ayudamos a crecer.",
  },
];
---

<section class="bg-white dark:bg-bg-darkest px-6 max-w-5xl mx-auto py-24">
  <span class="text-brand font-medium text-sm tracking-widest uppercase">
    Cómo trabajamos
  </span>
  <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900 dark:text-white mt-3 mb-16">
    Un proceso claro,<br />resultados reales.
  </h2>
  <div class="grid sm:grid-cols-3 gap-8">
    {
      pasos.map((p) => (
        <div>
          <span class="text-5xl font-bold text-brand/10 dark:text-brand/15 tracking-tight">{p.numero}</span>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mt-4 mb-3">{p.titulo}</h3>
          <p class="text-gray-500 dark:text-text-muted-dark leading-relaxed">{p.descripcion}</p>
        </div>
      ))
    }
  </div>
</section>
