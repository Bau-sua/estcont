---
const testimonios = [
  {
    cita: "Cambiamos de estudio contable porque necesitábamos algo más que liquidar impuestos. Con IS transformamos los números en información para tomar decisiones reales sobre el negocio.",
    autor: "Mariana López",
    empresa: "Urbana Indumentaria",
  },
  {
    cita: "Nos acompañaron desde la constitución de la sociedad hasta el día a día impositivo. Siempre un paso adelante, avisándonos antes de cada vencimiento y ayudándonos a planificar.",
    autor: "Gastón Ramírez",
    empresa: "Ramírez Instalaciones",
  },
];
---

<section class="bg-gray-50 dark:bg-bg-dark px-6 py-24">
  <div class="max-w-5xl mx-auto">
    <span class="text-brand font-medium text-sm tracking-widest uppercase">
      Testimonios
    </span>
    <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900 dark:text-white mt-3 mb-16">
      Lo dicen nuestros clientes.
    </h2>
    <div class="grid sm:grid-cols-2 gap-8">
      {
        testimonios.map((t) => (
          <blockquote class="border-l-2 border-brand pl-6">
            <p class="text-lg text-gray-600 dark:text-white/80 leading-relaxed mb-5">
              &ldquo;{t.cita}&rdquo;
            </p>
            <footer>
              <cite class="not-italic text-gray-900 dark:text-white font-medium text-sm">{t.autor}</cite>
              <span class="block text-gray-500 dark:text-text-muted-dark text-sm mt-0.5">{t.empresa}</span>
            </footer>
          </blockquote>
        ))
      }
    </div>
  </div>
</section>
