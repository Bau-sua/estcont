---
const testimonios = [
  {
    cita: "Desde que trabajamos con Numeria nos despreocupamos de la contabilidad. Responden siempre rápido y saben lo que hacen.",
    autor: "Mariana López",
    empresa: "Urbana Indumentaria",
  },
  {
    cita: "Cambié de contador tres veces hasta que los encontré. Cuota fija, todo digital, y me avisan antes de cada vencimiento.",
    autor: "Gastón Ramírez",
    empresa: "Ramírez Instalaciones",
  },
];
---

<section class="bg-teal-900 px-6 py-24">
  <div class="max-w-5xl mx-auto">
    <span class="text-teal-200 font-medium text-sm tracking-widest uppercase">
      Testimonios
    </span>
    <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-white mt-3 mb-16">
      Lo dicen nuestros clientes.
    </h2>
    <div class="grid sm:grid-cols-2 gap-8">
      {
        testimonios.map((t) => (
          <blockquote class="border-l-2 border-teal-500 pl-6">
            <p class="text-lg text-teal-50 leading-relaxed mb-5">
              &ldquo;{t.cita}&rdquo;
            </p>
            <footer>
              <cite class="not-italic text-white font-medium text-sm">{t.autor}</cite>
              <span class="block text-teal-300 text-sm mt-0.5">{t.empresa}</span>
            </footer>
          </blockquote>
        ))
      }
    </div>
  </div>
</section>
