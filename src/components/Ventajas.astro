---
const ventajas = [
  {
    titulo: "Cercanía y proactividad",
    descripcion: "Trabajamos de forma cercana y proactiva. No solo cumplimos con las obligaciones: nos anticipamos a los escenarios fiscales.",
  },
  {
    titulo: "Mirada estratégica",
    descripcion: "Transformamos la información contable en análisis real: rentabilidad, costos, flujo de fondos. Información para decidir, no solo para cumplir.",
  },
  {
    titulo: "Acompañamiento real",
    descripcion: "Desde el inicio del proyecto hasta el crecimiento. Servicio societario, impositivo y contable integral con seguimiento personalizado.",
  },
];
---

<section class="bg-gray-50 dark:bg-bg-dark px-6 py-24">
  <div class="max-w-5xl mx-auto">
    <span class="text-brand font-medium text-sm tracking-widest uppercase">
      Por qué IS
    </span>
    <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900 dark:text-white mt-3 mb-6">
      Más que contabilidad.
    </h2>
    <p class="text-gray-500 dark:text-text-muted-dark text-lg mb-16 max-w-2xl leading-relaxed">
      Creemos que la contabilidad no termina en impuestos y balances. 
      Acompañamos a nuestros clientes con una mirada estratégica que ayuda 
      a ordenar la gestión y anticiparse a los escenarios.
    </p>
    <div class="grid sm:grid-cols-3 gap-10">
      {
        ventajas.map((v) => (
          <div>
            <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">{v.titulo}</h3>
            <p class="text-gray-500 dark:text-text-muted-dark leading-relaxed">{v.descripcion}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
